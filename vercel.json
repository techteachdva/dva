{
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "devCommand": "npm run start",
  "redirects": [
    { "source": "/crystalwizards", "destination": "/crystalwizards/", "permanent": true },
    { "source": "/uriel", "destination": "/uriel/", "permanent": true },
    { "source": "/dragon-trail", "destination": "/dragon-trail/", "permanent": true },
    { "source": "/physix", "destination": "/physix/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/physix/", "destination": "/physix/physix.html" }
  ],
  "headers": [
    {
      "source": "/crystalwizards/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    },
    {
      "source": "/physix/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    },
    {
      "source": "/(.*)\\.wasm",
      "headers": [{ "key": "Content-Type", "value": "application/wasm" }]
    },
    {
      "source": "/(.*)\\.pck",
      "headers": [{ "key": "Content-Type", "value": "application/octet-stream" }]
    }
  ]
}
