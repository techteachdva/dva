; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Physix"
config/description="A physics-based slope game for middle school students. Navigate your ball through increasingly challenging worlds full of gravity zones, wind currents, bumpers, and more."
config/version="0.4.0"
config/tags=PackedStringArray("physics", "platformer", "educational")
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/stretch_mode=2
boot_splash/use_filter=false
boot_splash/image="res://assets/graphics/splash_screen.png"
config/icon="res://assets/graphics/game_icon.png"

[audio]

driver/output_latency=25

[autoload]

GameIcons="*res://scripts/autoloads/game_icons.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"
LevelManager="*res://scripts/autoloads/level_manager.gd"
TestHarness="*res://scripts/test_harness.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
GhostManager="*res://scripts/autoloads/ghost_manager.gd"
GhostAnalyzer="*res://scripts/autoloads/ghost_analyzer.gd"
CameraShaker="*res://scripts/autoloads/camera_shaker.gd"
ScreenFlash="*res://scenes/autoloads/screen_flash.tscn"
HitStop="*res://scripts/autoloads/hit_stop.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://assets/themes/default_theme.tres"

