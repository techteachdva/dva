size_flags_horizontal = 3
text = "🪙  x0"
theme_override_font_sizes/font_size = 18

[node name="SpeedBar" type="ProgressBar" parent="HUD"]
anchor_top = 1.0
anchor_bottom = 1.0
anchor_right = 1.0
offset_top = -18

