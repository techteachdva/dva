[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/game_level.gd" id="1"]
[ext_resource type="PackedScene" path="res://scenes/player/player.tscn" id="2"]
[ext_resource type="Script" path="res://scripts/hud.gd" id="3"]

[sub_resource type="BoxShape3D" id="FinishShape"]
size = Vector3(10, 4, 1)

; Base template — duplicate this and customise for each level.
; Track goes along -Z (forward = away from camera).
; Camera is placed in world space and follows the player via game_level.gd.

[node name="GameLevel" type="Node3D"]
script = ExtResource("1")

; ── Lighting ──────────────────────────────────────────────────────────────────
[node name="WorldEnvironment" type="WorldEnvironment" parent="."]

[node name="DirectionalLight3D" type="DirectionalLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.766, 0.643, 0, -0.643, 0.766, 0, 10, 5)
light_energy = 1.2
shadow_enabled = true

; ── Camera (positioned behind start, follows player via code) ─────────────────
[node name="Camera3D" type="Camera3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.94, -0.342, 0, 0.342, 0.94, 0, 6, 10)
fov = 75.0

; ── Player ────────────────────────────────────────────────────────────────────
[node name="Player" parent="." instance=ExtResource("2")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1.5, 0)

; ── Finish trigger ────────────────────────────────────────────────────────────
[node name="FinishZone" type="Area3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, -140)

[node name="FinishShape" type="CollisionShape3D" parent="FinishZone"]
shape = SubResource("FinishShape")

[node name="FinishMarker" type="MeshInstance3D" parent="FinishZone"]

; ── Respawn timer ─────────────────────────────────────────────────────────────
[node name="RespawnTimer" type="Timer" parent="."]
one_shot = true
wait_time = 0.5

; ── HUD (2D overlay on top of 3D scene) ──────────────────────────────────────
[node name="HUD" type="CanvasLayer" parent="."]
script = ExtResource("3")

[node name="TopBar" type="HBoxContainer" parent="HUD"]
anchor_right = 1.0
offset_bottom = 48
theme_override_constants/separation = 20

[node name="ScoreLabel" type="Label" parent="HUD/TopBar"]
size_flags_horizontal = 3
text = "Score  0000000"
theme_override_font_sizes/font_size = 18

[node name="TimerLabel" type="Label" parent="HUD/TopBar"]
size_flags_horizontal = 3
text = "00:00.00"
theme_override_font_sizes/font_size = 18

[node name="LivesLabel" type="Label" parent="HUD/TopBar"]
size_flags_horizontal = 3
text = "❤  x3"
theme_override_font_sizes/font_size = 18

